# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ADMETlab 3.0 API key (free registration at https://admetlab3.scbdd.com)
ADMETLAB_API_KEY=

# eMolecules API key for reagent pricing (https://www.emolecules.com/info/products-api.html)
EMOLECULES_API_KEY=

# HuggingFace token — required to download ReactionT5 backbone
# Get at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Data and checkpoint directories (absolute paths recommended on Windows)
DATA_DIR=data/
CHECKPOINT_DIR=checkpoints/
